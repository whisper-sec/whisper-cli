{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.whisper-sec/whisper",
  "description": "Keyless: verify agent identities & RDAP for a /128. With a key: register, govern & egress agents.",
  "version": "0.127.1",
  "repository": {
    "url": "https://github.com/whisper-sec/whisper-cli",
    "source": "github"
  },
  "websiteUrl": "https://whisper.online",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/whisper-sec/whisper:0.127.1",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
